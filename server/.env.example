# Copy this file to .env and edit values before running `docker compose up -d`.
# docker-compose.yml reads these to override Grafana defaults.

# Grafana admin credentials (change before exposing the dashboard publicly)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Webhook URL for alert notifications (Grafana -> your webhook server)
# Get this from Feishu/Lark flow or your own webhook endpoint.
# Example: WEBHOOK_URL=https://www.feishu.cn/flow/api/trigger-webhook/xxxxxx
WEBHOOK_URL=

# Optional: override host ports if 9090 / 3000 are already in use on the server
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
